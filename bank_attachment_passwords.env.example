# Copy this file to bank_attachment_passwords.env and fill real passwords locally.
# Do not commit the real password file.

# Fallback password used when no bank, filename, or pattern rule matches.
BANK_ATTACHMENT_PASSWORD_DEFAULT=

# Passwords keyed by bank_key from bank_email_records.jsonl.
# Value can be a single password string or a candidate password list.
BANK_ATTACHMENT_PASSWORD_BY_BANK_JSON={"cmb":"example-password","icbc":"example-password"}

# Passwords keyed by exact attachment filename.
# Value can be a single password string or a candidate password list.
BANK_ATTACHMENT_PASSWORD_BY_FILENAME_JSON={"statement.pdf":"example-password"}

# Passwords matched by substring in attachment filename or full path.
# Value can be a single password string or a candidate password list.
BANK_ATTACHMENT_PASSWORD_BY_PATTERN_JSON={"招商":"example-password","账单":"example-password"}

# Password candidates keyed by file type. Keys can be "pdf", ".pdf", "zip", or ".zip".
BANK_ATTACHMENT_PASSWORD_BY_TYPE_JSON={"pdf":["example-pdf-password-1","example-pdf-password-2"],"zip":["example-zip-password-1","example-zip-password-2"]}

# Optional prefixed aliases for file-type password lists.
BANK_ATTACHMENT_PDF_PWD=["example-pdf-password-1","example-pdf-password-2"]
BANK_ATTACHMENT_ZIP_PWD=["example-zip-password-1","example-zip-password-2"]
